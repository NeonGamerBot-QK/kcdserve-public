<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Admin — <%= content_for(:title) || "KCDServe" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-slate-950">
    <div class="flex min-h-screen">
      <%= render "admin/shared/sidebar" %>

      <div class="flex-1 flex flex-col">
        <%= render "admin/shared/topbar" %>

        <% if flash[:notice] %>
          <div class="max-w-7xl mx-auto mt-3 px-4 w-full">
            <div class="p-4 text-sm text-green-800 rounded-xl bg-green-50 border border-green-200" role="alert">
              <span class="font-medium"><%= flash[:notice] %></span>
            </div>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="max-w-7xl mx-auto mt-3 px-4 w-full">
            <div class="p-4 text-sm text-red-800 rounded-xl bg-red-50 border border-red-200" role="alert">
              <span class="font-medium"><%= flash[:alert] %></span>
            </div>
          </div>
        <% end %>

        <% if flash[:error] %>
          <div class="max-w-7xl mx-auto mt-3 px-4 w-full">
            <div class="p-4 text-sm text-red-800 rounded-xl bg-red-50 border border-red-200" role="alert">
              <span class="font-medium"><%= flash[:error] %></span>
            </div>
          </div>
        <% end %>

        <main class="max-w-7xl mx-auto px-4 py-6 w-full flex-1">
          <%= yield %>
        </main>
      </div>
    </div>

    <%= javascript_importmap_tags %>
    <%= yield :admin_css %>
  </body>
</html>
