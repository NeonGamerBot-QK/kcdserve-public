<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Admin — <%= content_for(:title) || "KCDServe" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body>
    <div class="flex">
      <%= render "admin/shared/sidebar" %>

      <div class="flex-1">
        <%= render "admin/shared/topbar" %>
        <%= render "admin/shared/topbar" %>

        <% if flash[:notice] %>
          <div class="max-w-7xl mx-auto mt-3 p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50" role="alert">
            <span class="font-medium"><%= flash[:notice] %></span>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="max-w-7xl mx-auto mt-3 p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
            <span class="font-medium"><%= flash[:alert] %></span>
          </div>
        <% end %>

        <% if flash[:error] %>
          <div class="max-w-7xl mx-auto mt-3 p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
            <span class="font-medium"><%= flash[:error] %></span>
          </div>
        <% end %>

        <main class="max-w-7xl mx-auto px-4 py-4">
            <%= yield %>
            <%= yield %>
        </main>
      </div>
    </div>

    <%= javascript_importmap_tags %>
    <%= yield :admin_css %>
  </body>
</html>
