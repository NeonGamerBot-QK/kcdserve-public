<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "KCDServe" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="KCDServe">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  
  </head>
  <body>
    <%= render "shared/navbar" %>

    <% if flash[:notice] %>
      <div class="container mt-3 p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50" role="alert">
        <span class="font-medium"><%= flash[:notice] %></span>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="container mt-3 p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
        <span class="font-medium"><%= flash[:alert] %></span>
      </div>
    <% end %>

    <% if flash[:error] %>
      <div class="container mt-3 p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50" role="alert">
        <span class="font-medium"><%= flash[:error] %></span>
      </div>
    <% end %>

    <main class="container py-4">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>

    <%= javascript_importmap_tags %>
    <%= yield :admin_css %>
  </body>
</html>
