<p style="margin: 0 0 16px; font-size: 16px; color: #1e293b;">Hi <%= @user.first_name %>,</p>

<p style="margin: 0 0 24px; font-size: 15px; color: #475569; line-height: 1.6;">Your login code is:</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td align="center" style="background-color: #f1f5f9; border-radius: 8px; padding: 20px 0;">
      <span style="font-size: 36px; font-weight: 700; letter-spacing: 0.3em; color: #1e293b; font-family: 'Courier New', monospace;"><%= @pin %></span>
    </td>
  </tr>
</table>

<p style="margin: 0 0 8px; font-size: 13px; color: #94a3b8;">This code will expire in 10 minutes.</p>
<p style="margin: 0; font-size: 13px; color: #94a3b8;">If you didn't request this, please ignore this email.</p>
