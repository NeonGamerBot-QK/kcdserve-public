<% if Rails.env.development? && !current_user.super_admin? %>
  <div class="mb-4">
    <%= button_to "Promote to Super Admin", dev_promote_path, method: :post, class: "border-2 border-dashed border-green-500 rounded px-4 py-2 text-green-700 hover:bg-green-50" %>
  </div>
<% end %>

<h1 class="text-2xl font-bold mb-6">Welcome back, <%= current_user.first_name %>!</h1>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-blue-600 text-white rounded-lg p-4 text-center">
    <h3 class="text-3xl font-bold"><%= @total_hours %></h3>
    <p class="mb-0">Approved Hours</p>
  </div>
  <div class="bg-yellow-500 text-white rounded-lg p-4 text-center">
    <h3 class="text-3xl font-bold"><%= @pending_count %></h3>
    <p class="mb-0">Pending Reviews</p>
  </div>
  <div class="bg-green-600 text-white rounded-lg p-4 text-center">
    <h3 class="text-3xl font-bold"><%= @groups.count %></h3>
    <p class="mb-0">Groups</p>
  </div>
  <div class="bg-cyan-600 text-white rounded-lg p-4 text-center">
    <h3 class="text-3xl font-bold"><%= @upcoming_signups.count %></h3>
    <p class="mb-0">Upcoming Events</p>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-white rounded-lg border shadow-sm">
    <div class="flex justify-between items-center p-4 border-b">
      <h5 class="mb-0 font-semibold">Recent Hours</h5>
      <%= link_to "Log Hours", new_service_hour_path, class: "bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700" %>
    </div>
    <div class="p-4">
      <% if @recent_hours.any? %>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b">
              <th class="text-left py-2">Date</th>
              <th class="text-left py-2">Hours</th>
              <th class="text-left py-2">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_hours.each do |sh| %>
              <tr class="border-b">
                <td class="py-2"><%= link_to sh.service_date.strftime("%m/%d/%Y"), service_hour_path(sh), class: "text-blue-600 hover:underline" %></td>
                <td class="py-2"><%= sh.hours %></td>
                <td class="py-2">
                  <span class="px-2 py-1 rounded text-xs text-white <%= sh.approved? ? 'bg-green-500' : sh.pending? ? 'bg-yellow-500' : 'bg-red-500' %>">
                    <%= sh.status.humanize %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-gray-500">No service hours logged yet.</p>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-lg border shadow-sm">
    <div class="p-4 border-b">
      <h5 class="mb-0 font-semibold">Upcoming Opportunities</h5>
    </div>
    <div class="p-4">
      <% if @upcoming_signups.any? %>
        <ul class="divide-y">
          <% @upcoming_signups.each do |opp| %>
            <li class="py-3 first:pt-0 last:pb-0">
              <div>
                <strong><%= link_to opp.title, opportunity_path(opp), class: "text-blue-600 hover:underline" %></strong>
                <br><small class="text-gray-500"><%= opp.date.strftime("%B %d, %Y") %></small>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-500">No upcoming events.</p>
      <% end %>
    </div>
  </div>
</div>
