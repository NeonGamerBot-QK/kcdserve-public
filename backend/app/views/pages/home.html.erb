<% if Rails.env.development? %>
  <div class="text-center mt-4">
    <%= button_to "Dev Login", dev_login_path, method: :post, class: "border-2 border-dashed border-green-500 rounded-xl px-4 py-2 text-green-700 dark:text-green-300 hover:bg-green-50 dark:hover:bg-green-950 text-sm" %>
  </div>
<% end %>

<div class="max-w-md mx-auto">
  <%# Welcome heading — matches mobile login %>
  <div class="mt-8 mb-6">
    <h1 class="font-semibold text-2xl text-slate-900 dark:text-white">Welcome back</h1>
    <p class="text-base text-slate-500 dark:text-slate-400 mt-1">Sign in to continue logging your service hours</p>
  </div>

  <% unless user_signed_in? %>
    <% if Flipper.enabled?(:magic_link_login) %>
      <%# Email card — matches mobile Card + TextInput + Pressable %>
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-5 mb-4">
        <%= form_with(url: auth_magic_login_path, local: true) do |f| %>
          <div class="grid grid-cols-2 gap-3 mb-3">
            <div>
              <%= f.label :first_name, "First Name", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5" %>
              <%= f.text_field :first_name, class: "w-full bg-slate-50 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-xl px-4 py-3 text-base text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", placeholder: "Jane" %>
            </div>
            <div>
              <%= f.label :last_name, "Last Name", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5" %>
              <%= f.text_field :last_name, class: "w-full bg-slate-50 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-xl px-4 py-3 text-base text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", placeholder: "Doe" %>
            </div>
          </div>
          <p class="text-xs text-slate-400 mb-4">Name fields are only needed for first-time sign up.</p>

          <div class="mb-5">
            <%= f.label :email, "Email", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5" %>
            <%= f.email_field :email, class: "w-full bg-slate-50 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-xl px-4 py-3 text-base text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", placeholder: "student@school.edu", required: true %>
          </div>

          <%= f.submit "Send Magic Link", class: "w-full bg-primary-500 text-white rounded-xl py-3.5 text-base font-semibold hover:bg-primary-600 cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <% if ENV["GOOGLE_CLIENT_ID"].present? %>
      <% if Flipper.enabled?(:magic_link_login) %>
        <%# OR divider — only shown when both auth options are visible %>
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
          <span class="font-medium text-sm text-slate-400 mx-4">OR</span>
          <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
        </div>
      <% end %>

      <%# Google button — matches mobile %>
      <div class="mb-8">
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "w-full flex items-center justify-center bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 text-base font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700", data: { turbo: false } do %>
          <svg class="w-5 h-5 mr-3" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Continue with Google
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# Browse Opportunities CTA %>
  <div class="text-center mb-8">
    <%= link_to "Browse Opportunities", opportunities_path, class: "inline-block bg-white dark:bg-slate-800 border-2 border-primary-500 text-primary-500 px-6 py-3 rounded-xl hover:bg-primary-50 dark:hover:bg-primary-950 text-base font-medium" %>
  </div>
</div>

<% if @upcoming_opportunities.any? %>
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center my-8">
      <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
      <span class="font-semibold text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider mx-4">Upcoming Opportunities</span>
      <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
    </div>

    <div class="space-y-2">
      <% @upcoming_opportunities.each do |opportunity| %>
        <%= link_to opportunity_path(opportunity), class: "block" do %>
          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 flex items-center py-3 px-5">
            <div class="w-10 h-10 rounded-full bg-primary-50 dark:bg-primary-500/20 flex items-center justify-center mr-3 flex-shrink-0">
              <span class="text-primary-500">&#128197;</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-sm text-slate-900 dark:text-white truncate"><%= opportunity.title %></p>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                <%= opportunity.date.strftime("%b %d, %Y") %>
                · <%= opportunity.location || "TBD" %>
              </p>
            </div>
            <div class="text-right ml-3 flex-shrink-0">
              <% if opportunity.category %>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color: <%= opportunity.category.color %>;">
                  <%= opportunity.category.name %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
