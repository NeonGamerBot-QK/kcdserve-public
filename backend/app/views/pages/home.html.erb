<% if Rails.env.development? %>
  <div class="text-center my-3">
    <%= button_to "Dev Login", dev_login_path, method: :post, class: "btn btn-outline-success", style: "border-style: dashed;" %>
  </div>
<% end %>

<div class="text-center py-5">
  <h1 class="display-4 fw-bold">Make a Difference in Your Community</h1>
  <p class="lead text-muted">Track your volunteer hours, discover opportunities, and build your service resume.</p>
</div>

<% unless user_signed_in? %>
  <div class="row justify-content-center mb-5">
    <div class="col-md-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title text-center mb-3">Sign In or Sign Up</h5>

          <%# Magic link form with optional name fields for new users %>
          <%= form_with(url: auth_magic_login_path, local: true) do |f| %>
            <div class="row g-2 mb-3">
              <div class="col-6">
                <%= f.label :first_name, "First Name", class: "form-label" %>
                <%= f.text_field :first_name, class: "form-control", placeholder: "Jane" %>
              </div>
              <div class="col-6">
                <%= f.label :last_name, "Last Name", class: "form-label" %>
                <%= f.text_field :last_name, class: "form-control", placeholder: "Doe" %>
              </div>
            </div>
            <p class="text-muted small mb-3">Name fields are only needed for first-time sign up.</p>

            <div class="mb-3">
              <%= f.label :email, "Email Address", class: "form-label" %>
              <%= f.email_field :email, class: "form-control", placeholder: "you@example.com", required: true %>
            </div>
            <div class="d-grid">
              <%= f.submit "Send Magic Link", class: "btn btn-primary" %>
            </div>
          <% end %>

          <%# Google OAuth2 button (only shown when configured) %>
          <% if !Rails.env.development? && ENV["GOOGLE_CLIENT_ID"].present? %>
            <div class="text-center my-3">
              <span class="text-muted">— or —</span>
            </div>
            <div class="d-grid">
              <%= button_to "Sign in with Google", user_google_oauth2_omniauth_authorize_path, method: :post, class: "btn btn-outline-dark", data: { turbo: false } %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="text-center mb-4">
  <%= link_to "Browse Opportunities", opportunities_path, class: "btn btn-outline-primary btn-lg" %>
</div>

<% if @upcoming_opportunities.any? %>
  <hr class="my-5">
  <h2 class="text-center mb-4">Upcoming Opportunities</h2>
  <div class="row g-4">
    <% @upcoming_opportunities.each do |opportunity| %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title"><%= opportunity.title %></h5>
            <p class="text-muted">
              <i class="bi bi-calendar me-1"></i> <%= opportunity.date.strftime("%B %d, %Y") %>
            </p>
            <p class="text-muted">
              <i class="bi bi-geo-alt me-1"></i> <%= opportunity.location || "TBD" %>
            </p>
            <% if opportunity.category %>
              <span class="badge" style="background-color: <%= opportunity.category.color %>;">
                <%= opportunity.category.name %>
              </span>
            <% end %>
          </div>
          <div class="card-footer bg-transparent">
            <%= link_to "View Details", opportunity_path(opportunity), class: "btn btn-sm btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
