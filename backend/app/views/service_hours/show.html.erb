<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="md:col-span-2">
    <h1 class="text-2xl font-bold mb-4">Service Hour Details</h1>

    <div class="bg-white rounded-lg border shadow-sm mb-4">
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <% if @service_hour.title.present? %>
              <p class="mb-2"><strong class="font-medium">Title:</strong> <%= @service_hour.title %></p>
            <% end %>
            <p class="mb-2"><strong class="font-medium">Volunteer:</strong> <%= @service_hour.user&.full_name || "Deleted User" %></p>
            <p class="mb-2"><strong class="font-medium">Date:</strong> <%= @service_hour.service_date.strftime("%B %d, %Y") %></p>
            <p class="mb-2"><strong class="font-medium">Hours:</strong> <%= @service_hour.hours %></p>
            <p class="mb-2"><strong class="font-medium">Category:</strong> <%= @service_hour.category.name %></p>
          </div>
          <div>
            <p class="mb-2"><strong class="font-medium">Group:</strong> <%= @service_hour.group&.name || "N/A" %></p>
            <p class="mb-2"><strong class="font-medium">Opportunity:</strong> <%= @service_hour.opportunity&.title || "N/A" %></p>
            <p class="mb-2"><strong class="font-medium">On Campus:</strong> <%= @service_hour.on_campus? ? "Yes" : "No" %></p>
            <% if @service_hour.organization_name.present? %>
              <p class="mb-2"><strong class="font-medium">Organization:</strong> <%= @service_hour.organization_name %></p>
            <% end %>
            <% if @service_hour.contact_name.present? %>
              <p class="mb-2"><strong class="font-medium">Contact:</strong> <%= @service_hour.contact_name %></p>
            <% end %>
            <% if @service_hour.contact_email.present? %>
              <p class="mb-2"><strong class="font-medium">Contact Email:</strong> <%= mail_to @service_hour.contact_email %></p>
            <% end %>
            <p class="mb-2">
              <strong class="font-medium">Status:</strong>
              <span class="ml-2 px-2 py-1 rounded text-xs text-white <%= @service_hour.approved? ? 'bg-green-500' : @service_hour.pending? ? 'bg-yellow-500' : 'bg-red-500' %>">
                <%= @service_hour.status.humanize %>
              </span>
            </p>
            <% if @service_hour.reviewer %>
              <p class="mb-2"><strong class="font-medium">Reviewed by:</strong> <%= @service_hour.reviewer.full_name %></p>
              <p class="mb-2"><strong class="font-medium">Reviewed at:</strong> <%= @service_hour.reviewed_at&.strftime("%B %d, %Y %I:%M %p") %></p>
            <% end %>
          </div>
        </div>
        <hr class="my-4">
        <h6 class="font-semibold mb-2">Description</h6>
        <p><%= simple_format(@service_hour.description) %></p>

        <% if @service_hour.admin_comment.present? %>
          <hr class="my-4">
          <h6 class="font-semibold mb-2">Admin Comment</h6>
          <p class="text-gray-600"><%= @service_hour.admin_comment %></p>
        <% end %>
      </div>
    </div>

    <% if @service_hour.photos.attached? %>
      <h5 class="font-semibold mb-3">Photos</h5>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4">
        <% @service_hour.photos.each do |photo| %>
          <div>
            <%= image_tag photo, class: "w-full rounded" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="md:col-span-1">
    <% if @service_hour.editor.present? %>
      <div class="bg-white rounded-lg border shadow-sm mb-3 p-4">
        <p class="text-gray-500 mb-0 text-sm">
          Last edited by <strong><%= @service_hour.editor.full_name %></strong>
          on <%= @service_hour.edited_at&.strftime("%B %d, %Y %I:%M %p") %>
        </p>
      </div>
    <% end %>

    <% if @service_hour.user == current_user && @service_hour.pending? %>
      <div class="bg-white rounded-lg border shadow-sm mb-3 p-4">
        <div class="space-y-2">
          <%= link_to "Edit", edit_service_hour_path(@service_hour), class: "block w-full text-center border border-blue-600 text-blue-600 rounded px-4 py-2 hover:bg-blue-50" %>
          <%= button_to "Delete", service_hour_path(@service_hour), method: :delete, class: "block w-full text-center border border-red-500 text-red-500 rounded px-4 py-2 hover:bg-red-50", data: { turbo_confirm: "Are you sure?" } %>
        </div>
      </div>
    <% elsif current_user.staff? %>
      <div class="bg-white rounded-lg border shadow-sm mb-3 p-4">
        <%= link_to "Edit", edit_service_hour_path(@service_hour), class: "block w-full text-center border border-blue-600 text-blue-600 rounded px-4 py-2 hover:bg-blue-50" %>
      </div>
    <% end %>

    <% if current_user.admin_or_above? && @service_hour.pending? %>
      <div class="bg-white rounded-lg border-2 border-dashed border-orange-400 shadow-sm">
        <div class="p-4 border-b">
          <h5 class="mb-0 font-semibold">Review</h5>
        </div>
        <div class="p-4">
          <%= form_with(url: review_service_hour_path(@service_hour), method: :patch, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :admin_comment, "Comment", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_area :admin_comment, class: "w-full px-3 py-2 border rounded", rows: 3, name: "admin_comment" %>
            </div>
            <div class="space-y-2">
              <button type="submit" name="status" value="approved" class="w-full bg-green-600 text-white rounded px-4 py-2 hover:bg-green-700">
                Approve
              </button>
              <button type="submit" name="status" value="rejected" class="w-full bg-red-600 text-white rounded px-4 py-2 hover:bg-red-700">
                Reject
              </button>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-4">
  <%= link_to "← Back to Service Hours", service_hours_path, class: "text-gray-600 hover:text-gray-800" %>
</div>
