<div class="row">
  <div class="col-md-8">
    <h1>Service Hour Details</h1>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><strong>Volunteer:</strong> <%= @service_hour.user.full_name %></p>
            <p><strong>Date:</strong> <%= @service_hour.service_date.strftime("%B %d, %Y") %></p>
            <p><strong>Hours:</strong> <%= @service_hour.hours %></p>
            <p><strong>Category:</strong> <%= @service_hour.category.name %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Group:</strong> <%= @service_hour.group&.name || "N/A" %></p>
            <p><strong>Opportunity:</strong> <%= @service_hour.opportunity&.title || "N/A" %></p>
            <p>
              <strong>Status:</strong>
              <span class="badge bg-<%= @service_hour.approved? ? 'success' : @service_hour.pending? ? 'warning' : 'danger' %>">
                <%= @service_hour.status.humanize %>
              </span>
            </p>
            <% if @service_hour.reviewer %>
              <p><strong>Reviewed by:</strong> <%= @service_hour.reviewer.full_name %></p>
              <p><strong>Reviewed at:</strong> <%= @service_hour.reviewed_at&.strftime("%B %d, %Y %I:%M %p") %></p>
            <% end %>
          </div>
        </div>
        <hr>
        <h6>Description</h6>
        <p><%= simple_format(@service_hour.description) %></p>

        <% if @service_hour.admin_comment.present? %>
          <hr>
          <h6>Admin Comment</h6>
          <p class="text-muted"><%= @service_hour.admin_comment %></p>
        <% end %>
      </div>
    </div>

    <% if @service_hour.photos.attached? %>
      <h5>Photos</h5>
      <div class="row g-2 mb-4">
        <% @service_hour.photos.each do |photo| %>
          <div class="col-md-4">
            <%= image_tag photo, class: "img-fluid rounded" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <% if @service_hour.user == current_user && @service_hour.pending? %>
      <div class="card mb-3">
        <div class="card-body d-grid gap-2">
          <%= link_to "Edit", edit_service_hour_path(@service_hour), class: "btn btn-outline-primary" %>
          <%= button_to "Delete", service_hour_path(@service_hour), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
        </div>
      </div>
    <% end %>

    <% if current_user.admin_or_above? && @service_hour.pending? %>
      <div class="card">
        <div class="card-header"><h5 class="mb-0">Review</h5></div>
        <div class="card-body">
          <%= form_with(url: review_service_hour_path(@service_hour), method: :patch, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :admin_comment, "Comment", class: "form-label" %>
              <%= f.text_area :admin_comment, class: "form-control", rows: 3, name: "admin_comment" %>
            </div>
            <div class="d-grid gap-2">
              <button type="submit" name="status" value="approved" class="btn btn-success">
                <i class="bi bi-check-circle me-1"></i> Approve
              </button>
              <button type="submit" name="status" value="rejected" class="btn btn-danger">
                <i class="bi bi-x-circle me-1"></i> Reject
              </button>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to "← Back to Service Hours", service_hours_path, class: "btn btn-outline-secondary" %>
</div>
