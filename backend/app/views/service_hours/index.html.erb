<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">My Service Hours</h1>
  <%= link_to "Log New Hours", new_service_hour_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<% if @service_hours.any? %>
  <div class="bg-white rounded-lg border shadow-sm overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Date</th>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Hours</th>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Category</th>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Group</th>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Status</th>
          <th class="text-left px-4 py-3 text-sm font-medium text-gray-600"></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @service_hours.each do |sh| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3"><%= sh.service_date.strftime("%m/%d/%Y") %></td>
            <td class="px-4 py-3"><%= sh.hours %></td>
            <td class="px-4 py-3"><%= sh.category.name %></td>
            <td class="px-4 py-3"><%= sh.group&.name || "—" %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-1 rounded text-xs text-white <%= sh.approved? ? 'bg-green-500' : sh.pending? ? 'bg-yellow-500' : 'bg-red-500' %>">
                <%= sh.status.humanize %>
              </span>
            </td>
            <td class="px-4 py-3">
              <%= link_to "View", service_hour_path(sh), class: "text-blue-600 hover:text-blue-800 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
  </div>
<% else %>
  <div class="text-center py-12">
    <p class="text-gray-500 text-lg mb-4">You haven't logged any service hours yet.</p>
    <%= link_to "Log Your First Hours", new_service_hour_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>
<% end %>
