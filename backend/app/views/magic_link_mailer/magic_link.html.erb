<p style="margin: 0 0 16px; font-size: 16px; color: #1e293b;">Hi <%= @user.first_name %>,</p>

<p style="margin: 0 0 24px; font-size: 15px; color: #475569; line-height: 1.6;">Click the button below to sign in to your account:</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto 24px;">
  <tr>
    <td align="center" style="background-color: #3b82f6; border-radius: 8px;">
      <%= link_to "Sign in to KCDServe", @magic_link_url, style: "display: inline-block; padding: 14px 32px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none;" %>
    </td>
  </tr>
</table>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td style="border-top: 1px solid #e2e8f0; padding-top: 16px;">
      <p style="margin: 0 0 4px; font-size: 13px; color: #94a3b8;">Or copy this link into your browser:</p>
      <p style="margin: 0; font-size: 13px; color: #3b82f6; word-break: break-all;"><%= @magic_link_url %></p>
    </td>
  </tr>
</table>

<p style="margin: 0 0 8px; font-size: 13px; color: #94a3b8;">This link will expire in 15 minutes.</p>
<p style="margin: 0; font-size: 13px; color: #94a3b8;">If you didn't request this, please ignore this email.</p>
