<%= form_with(model: opportunity, class: "needs-validation") do |f| %>
  <% if opportunity.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(opportunity.errors.count, "error") %> prevented saving:</h6>
      <ul class="mb-0">
        <% opportunity.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <div class="mb-3">
        <%= f.label :title, class: "form-label" %>
        <%= f.text_field :title, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :category_id, "Category", class: "form-label" %>
        <%= f.collection_select :category_id, Category.order(:name), :id, :name, { include_blank: "Select category" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 5 %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :date, class: "form-label" %>
        <%= f.date_field :date, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :start_time, class: "form-label" %>
        <%= f.time_field :start_time, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :end_time, class: "form-label" %>
        <%= f.time_field :end_time, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :location, class: "form-label" %>
        <%= f.text_field :location, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-3">
      <div class="mb-3">
        <%= f.label :required_hours, class: "form-label" %>
        <%= f.number_field :required_hours, class: "form-control", step: 0.25 %>
      </div>
    </div>
    <div class="col-md-3">
      <div class="mb-3">
        <%= f.label :max_volunteers, class: "form-label" %>
        <%= f.number_field :max_volunteers, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :photos, class: "form-label" %>
        <%= f.file_field :photos, class: "form-control", multiple: true, accept: "image/*" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3 pt-4">
        <div class="form-check">
          <%= f.check_box :published, class: "form-check-input" %>
          <%= f.label :published, "Publish (visible to public)", class: "form-check-label" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", opportunities_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
