<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="md:col-span-2">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-3"><%= @opportunity.title %></h1>
    <div class="flex flex-wrap gap-2 mb-4">
      <% if @opportunity.category %>
        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color: <%= @opportunity.category.color %>;">
          <%= @opportunity.category.name %>
        </span>
      <% end %>
      <% unless @opportunity.published? %>
        <span class="px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-xs font-medium">Draft</span>
      <% end %>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div class="space-y-2">
          <p><span class="mr-1">&#128197;</span> <span class="font-medium text-slate-500 dark:text-slate-400">Date:</span> <span class="text-slate-900 dark:text-white"><%= @opportunity.date.strftime("%B %d, %Y") %></span></p>
          <% if @opportunity.start_time %>
            <p><span class="mr-1">&#128336;</span> <span class="font-medium text-slate-500 dark:text-slate-400">Time:</span> <span class="text-slate-900 dark:text-white"><%= @opportunity.start_time.strftime("%I:%M %p") %><%= " — #{@opportunity.end_time.strftime('%I:%M %p')}" if @opportunity.end_time %></span></p>
          <% end %>
        </div>
        <div class="space-y-2">
          <p><span class="mr-1">&#128205;</span> <span class="font-medium text-slate-500 dark:text-slate-400">Location:</span> <span class="text-slate-900 dark:text-white"><%= @opportunity.location || "TBD" %></span></p>
          <% if @opportunity.required_hours %>
            <p><span class="mr-1">&#9201;</span> <span class="font-medium text-slate-500 dark:text-slate-400">Required Hours:</span> <span class="text-slate-900 dark:text-white"><%= @opportunity.required_hours %></span></p>
          <% end %>
          <% if @opportunity.max_volunteers %>
            <p><span class="mr-1">&#128101;</span> <span class="font-medium text-slate-500 dark:text-slate-400">Spots:</span> <span class="text-slate-900 dark:text-white"><%= @opportunity.spots_remaining %> of <%= @opportunity.max_volunteers %> remaining</span></p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mb-6">
      <h5 class="font-semibold text-slate-900 dark:text-white mb-2">Description</h5>
      <p class="text-slate-600 dark:text-slate-300"><%= simple_format(@opportunity.description) %></p>
    </div>

    <% if @opportunity.photos.attached? %>
      <h5 class="font-semibold text-slate-900 dark:text-white mb-3">Photos</h5>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4">
        <% @opportunity.photos.each do |photo| %>
          <div>
            <%= image_tag photo, class: "w-full rounded-xl" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6">
      <% if user_signed_in? %>
        <% if @signed_up %>
          <p class="text-status-approved text-sm font-medium mb-3">&#10003; You are signed up!</p>
          <%= button_to "Withdraw", withdraw_opportunity_path(@opportunity), method: :delete, class: "w-full border border-red-500 text-red-500 rounded-xl px-4 py-2 hover:bg-red-50 dark:hover:bg-red-950 font-medium text-sm" %>
        <% elsif !@opportunity.full? %>
          <%= button_to "Sign Up", signup_opportunity_path(@opportunity), method: :post, class: "w-full bg-primary-500 text-white rounded-xl px-4 py-2 hover:bg-primary-600 font-medium text-sm" %>
        <% else %>
          <p class="text-status-rejected text-sm font-medium">This opportunity is full.</p>
        <% end %>
      <% else %>
        <p class="text-slate-500 dark:text-slate-400 text-sm">Please <%= link_to "sign in", new_user_session_path, class: "text-primary-500 hover:text-primary-700" %> to sign up.</p>
      <% end %>

      <hr class="my-4 border-gray-200 dark:border-slate-700">

      <% if user_signed_in? && current_user.admin_or_above? %>
        <div class="space-y-2">
          <%= link_to "Edit", edit_opportunity_path(@opportunity), class: "block w-full text-center border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-xl px-4 py-2 hover:bg-slate-50 dark:hover:bg-slate-700 font-medium text-sm" %>
          <%= button_to "Delete", opportunity_path(@opportunity), method: :delete, class: "w-full border border-red-500 text-red-500 rounded-xl px-4 py-2 hover:bg-red-50 dark:hover:bg-red-950 font-medium text-sm", data: { turbo_confirm: "Are you sure?" } %>
        </div>
        <hr class="my-4 border-gray-200 dark:border-slate-700">
        <p class="text-slate-500 dark:text-slate-400 text-sm"><span class="font-medium">Signed up:</span> <%= @opportunity.volunteers.count %></p>
      <% end %>
    </div>
  </div>
</div>
