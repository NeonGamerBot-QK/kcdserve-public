<h1>Edit Profile</h1>

<%= form_with(model: @user, url: profile_path(@user), class: "needs-validation") do |f| %>
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :first_name, class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :last_name, class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :phone, class: "form-label" %>
        <%= f.text_field :phone, class: "form-control" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :avatar, "Profile Photo", class: "form-label" %>
        <%= f.file_field :avatar, class: "form-control", accept: "image/*" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :birthday, class: "form-label" %>
        <%= f.date_field :birthday, class: "form-control" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :bio, class: "form-label" %>
        <%= f.text_area :bio, class: "form-control", rows: 4 %>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit "Update Profile", class: "btn btn-primary" %>
    <%= link_to "Cancel", profile_path(@user), class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
