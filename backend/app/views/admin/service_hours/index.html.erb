<h1 class="mb-4">Service Hours Review</h1>

<div class="mb-3">
  <div class="btn-group" role="group">
    <%= link_to "All", admin_service_hours_path, class: "btn btn-outline-primary #{'active' unless params[:status].present?}" %>
    <%= link_to "Pending", admin_service_hours_path(status: :pending), class: "btn btn-outline-warning #{'active' if params[:status] == 'pending'}" %>
    <%= link_to "Approved", admin_service_hours_path(status: :approved), class: "btn btn-outline-success #{'active' if params[:status] == 'approved'}" %>
    <%= link_to "Rejected", admin_service_hours_path(status: :rejected), class: "btn btn-outline-danger #{'active' if params[:status] == 'rejected'}" %>
  </div>
</div>

<table class="table table-hover">
  <thead>
    <tr>
      <th>Volunteer</th>
      <th>Date</th>
      <th>Hours</th>
      <th>Category</th>
      <th>Group</th>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @service_hours.each do |sh| %>
      <tr>
        <td><%= sh.user&.full_name || "Deleted User" %></td>
        <td><%= sh.service_date.strftime("%m/%d/%Y") %></td>
        <td><%= sh.hours %></td>
        <td><%= sh.category.name %></td>
        <td><%= sh.group&.name || "—" %></td>
        <td>
          <span class="badge bg-<%= sh.approved? ? 'success' : sh.pending? ? 'warning' : 'danger' %>">
            <%= sh.status.humanize %>
          </span>
        </td>
        <td><%= link_to "Review", admin_service_hour_path(sh), class: "btn btn-sm btn-outline-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mt-3">
  <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
</div>
