<h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-2">Edit Service Hour</h1>

<p class="text-slate-500 dark:text-slate-400 text-sm mb-6">
  Submitted by <strong class="text-slate-700 dark:text-slate-300"><%= @service_hour.user.full_name %></strong>
  on <%= @service_hour.created_at.strftime("%B %d, %Y") %>
</p>

<%= form_with(model: [:admin, @service_hour], html: { novalidate: true }) do |f| %>
  <% if @service_hour.errors.any? %>
    <div class="bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 rounded-xl p-4 mb-6">
      <h6 class="font-semibold text-sm"><%= pluralize(@service_hour.errors.count, "error") %> prevented saving:</h6>
      <ul class="list-disc list-inside text-sm mt-1">
        <% @service_hour.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="md:col-span-3">
        <%= f.label :title, "Title (optional)", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :title, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", maxlength: 100, placeholder: "Short summary of the service" %>
      </div>
      <div>
        <%= f.label :service_date, "Date of Service", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.date_field :service_date, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
      </div>
      <div>
        <%= f.label :hours, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.number_field :hours, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", step: 0.25, min: 0.25, required: true %>
      </div>
      <div>
        <%= f.label :category_id, "Category", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.collection_select :category_id, Category.order(:name), :id, :name, { prompt: "Select category" }, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
      </div>
      <div>
        <%= f.label :group_id, "Group (optional)", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.collection_select :group_id, Group.order(:name), :id, :name, { include_blank: "No group" }, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :opportunity_id, "Opportunity (optional)", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.collection_select :opportunity_id, Opportunity.order(:title), :id, :title, { include_blank: "No specific opportunity" }, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div class="md:col-span-3">
        <%= f.label :description, "Description of Service", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_area :description, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", rows: 4, required: true %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :photos, "Photo Proof (optional)", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.file_field :photos, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white", multiple: true, accept: "image/*" %>
        <% if @service_hour.photos.attached? %>
          <p class="text-xs text-slate-400 mt-1"><%= @service_hour.photos.count %> photo(s) currently attached</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center space-x-3">
    <%= f.submit "Save Changes", class: "bg-primary-500 text-white px-5 py-2 rounded-xl text-sm font-medium hover:bg-primary-600 cursor-pointer" %>
    <%= link_to "Cancel", admin_service_hour_path(@service_hour), class: "border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 px-5 py-2 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700" %>
  </div>
<% end %>
