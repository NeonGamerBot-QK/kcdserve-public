<h1>Edit Service Hour</h1>

<p class="text-muted">
  Submitted by <strong><%= @service_hour.user.full_name %></strong>
  on <%= @service_hour.created_at.strftime("%B %d, %Y") %>
</p>

<%= form_with(model: [:admin, @service_hour], class: "needs-validation") do |f| %>
  <% if @service_hour.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(@service_hour.errors.count, "error") %> prevented saving:</h6>
      <ul class="mb-0">
        <% @service_hour.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :title, "Title (optional)", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", maxlength: 100, placeholder: "Short summary of the service" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :service_date, "Date of Service", class: "form-label" %>
        <%= f.date_field :service_date, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :hours, class: "form-label" %>
        <%= f.number_field :hours, class: "form-control", step: 0.25, min: 0.25, required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :category_id, "Category", class: "form-label" %>
        <%= f.collection_select :category_id, Category.order(:name), :id, :name, { prompt: "Select category" }, class: "form-select", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :group_id, "Group (optional)", class: "form-label" %>
        <%= f.collection_select :group_id, Group.order(:name), :id, :name, { include_blank: "No group" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :opportunity_id, "Opportunity (optional)", class: "form-label" %>
        <%= f.collection_select :opportunity_id, Opportunity.order(:title), :id, :title, { include_blank: "No specific opportunity" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, "Description of Service", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4, required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :photos, "Photo Proof (optional)", class: "form-label" %>
        <%= f.file_field :photos, class: "form-control", multiple: true, accept: "image/*" %>
        <% if @service_hour.photos.attached? %>
          <small class="text-muted"><%= @service_hour.photos.count %> photo(s) currently attached</small>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit "Save Changes", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_service_hour_path(@service_hour), class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
