<h1>Review Service Hour</h1>

<div class="row">
  <div class="col-md-8">
    <div class="card mb-4">
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <% if @service_hour.title.present? %>
              <p><strong>Title:</strong> <%= @service_hour.title %></p>
            <% end %>
            <p>
              <strong>Volunteer:</strong>
              <% if @service_hour.user %>
                <%= link_to @service_hour.user.full_name, admin_user_path(@service_hour.user) %>
                <% if @service_hour.user.deleted? %>
                  <span class="badge bg-secondary">Deactivated</span>
                <% end %>
              <% else %>
                <span class="text-muted">Deleted User</span>
              <% end %>
            </p>
            <p><strong>Date:</strong> <%= @service_hour.service_date.strftime("%B %d, %Y") %></p>
            <p><strong>Hours:</strong> <%= @service_hour.hours %></p>
            <p><strong>Category:</strong> <%= @service_hour.category.name %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Group:</strong> <%= @service_hour.group&.name || "N/A" %></p>
            <p>
              <strong>Status:</strong>
              <span class="badge bg-<%= @service_hour.approved? ? 'success' : @service_hour.pending? ? 'warning' : 'danger' %>">
                <%= @service_hour.status.humanize %>
              </span>
            </p>
          </div>
        </div>
        <hr>
        <h6>Description</h6>
        <p><%= simple_format(@service_hour.description) %></p>
      </div>
    </div>

    <% if @service_hour.photos.attached? %>
      <h5>Photo Proof</h5>
      <div class="row g-2 mb-4">
        <% @service_hour.photos.each do |photo| %>
          <div class="col-md-4">
            <%= image_tag photo, class: "img-fluid rounded" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <% if @service_hour.pending? %>
      <div class="card">
        <div class="card-header"><h5 class="mb-0">Review</h5></div>
        <div class="card-body">
          <%= form_with(url: review_admin_service_hour_path(@service_hour), method: :patch, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :admin_comment, "Comment", class: "form-label" %>
              <%= f.text_area :admin_comment, class: "form-control", rows: 3, name: "admin_comment" %>
            </div>
            <div class="d-grid gap-2">
              <button type="submit" name="status" value="approved" class="btn btn-success">
                <i class="bi bi-check-circle me-1"></i> Approve
              </button>
              <button type="submit" name="status" value="rejected" class="btn btn-danger">
                <i class="bi bi-x-circle me-1"></i> Reject
              </button>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card">
        <div class="card-body">
          <p><strong>Reviewed by:</strong> <%= @service_hour.reviewer&.full_name || "N/A" %></p>
          <p><strong>Reviewed at:</strong> <%= @service_hour.reviewed_at&.strftime("%B %d, %Y %I:%M %p") %></p>
          <% if @service_hour.admin_comment.present? %>
            <p><strong>Comment:</strong> <%= @service_hour.admin_comment %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @service_hour.editor.present? %>
  <div class="alert alert-info mt-3">
    <i class="bi bi-pencil-square me-1"></i>
    Last edited by <strong><%= @service_hour.editor.full_name %></strong>
    on <%= @service_hour.edited_at&.strftime("%B %d, %Y %I:%M %p") %>
  </div>
<% end %>

<div class="mt-3">
  <%= link_to "Edit", edit_admin_service_hour_path(@service_hour), class: "btn btn-outline-primary" %>
  <%= link_to "← Back", admin_service_hours_path, class: "btn btn-outline-secondary" %>
</div>
