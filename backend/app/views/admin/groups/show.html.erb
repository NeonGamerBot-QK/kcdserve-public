<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-white"><%= @group.name %></h1>
    <% if @group.leader %>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Led by <%= @group.leader.full_name %></p>
    <% end %>
  </div>
  <div class="flex items-center space-x-2">
    <% if current_user.admin_or_above? %>
      <%= link_to "Edit", edit_admin_group_path(@group), class: "border border-primary-500 text-primary-500 px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-50 dark:hover:bg-primary-950" %>
      <%= button_to "Delete", admin_group_path(@group), method: :delete, class: "border border-red-500 text-red-500 px-4 py-2 rounded-xl text-sm font-medium hover:bg-red-50 dark:hover:bg-red-950", data: { turbo_confirm: "Delete #{@group.name}? This cannot be undone." } %>
    <% end %>
    <%= link_to "← Back", admin_groups_path, class: "text-primary-500 hover:text-primary-700 text-sm font-medium" %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-5 text-center">
    <p class="text-2xl font-bold text-slate-900 dark:text-white"><%= @members.size %></p>
    <p class="text-sm text-slate-500 dark:text-slate-400">Members</p>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-5 text-center">
    <p class="text-2xl font-bold text-slate-900 dark:text-white"><%= @total_hours %></p>
    <p class="text-sm text-slate-500 dark:text-slate-400">Total Approved Hours</p>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-5 text-center">
    <p class="text-2xl font-bold text-slate-900 dark:text-white"><%= @group.invite_only? ? "Private" : "Open" %></p>
    <p class="text-sm text-slate-500 dark:text-slate-400">Membership</p>
  </div>
</div>

<% if current_user.admin_or_above? %>
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-5 mb-6">
    <h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Add Member</h4>
    <%= form_tag add_member_admin_group_path(@group), method: :post, class: "flex items-end gap-3" do %>
      <div class="flex-1">
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Select User</label>
        <%= select_tag :user_id,
          options_from_collection_for_select(@available_users, :id, :full_name),
          prompt: "Choose a user…",
          class: "w-full rounded-xl border border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white px-4 py-2 text-sm" %>
      </div>
      <%= submit_tag "Add to Group", class: "bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-600 cursor-pointer" %>
    <% end %>
  </div>
<% end %>

<h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Members</h4>
<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-hidden">
  <% if @members.any? %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 dark:bg-slate-700">
        <tr>
          <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Name</th>
          <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Email</th>
          <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Hours</th>
          <% if current_user.admin_or_above? %>
            <th class="px-4 py-3"></th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
        <% @members.each do |member| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-700">
            <td class="px-4 py-3"><%= link_to member.full_name, profile_path(member), class: "text-primary-500 hover:text-primary-700 font-medium" %></td>
            <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= member.email %></td>
            <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= member.total_approved_hours %></td>
            <% if current_user.admin_or_above? %>
              <td class="px-4 py-3 text-right">
                <%= button_to "Remove", remove_member_admin_group_path(@group, user_id: member.id), method: :delete, class: "text-red-500 hover:text-red-700 text-xs font-medium", data: { turbo_confirm: "Remove #{member.full_name} from #{@group.name}?" } %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-center text-slate-500 dark:text-slate-400">
      No members yet. Use the form above to add members.
    </div>
  <% end %>
</div>
