<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Manage Groups</h1>
  <% if current_user.admin_or_above? %>
    <%= link_to "Create Group", new_admin_group_path, class: "bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-600" %>
  <% end %>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 dark:bg-slate-700">
      <tr>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Name</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Leader</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Members</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Total Hours</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
      <% @groups.each do |group| %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700">
          <td class="px-4 py-3"><%= link_to group.name, admin_group_path(group), class: "text-primary-500 hover:text-primary-700 font-medium" %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= group.leader&.full_name || "—" %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= group.members.size %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= group.total_approved_hours %></td>
          <td class="px-4 py-3">
            <%= link_to "View", admin_group_path(group), class: "text-primary-500 hover:text-primary-700 text-xs font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
</div>
