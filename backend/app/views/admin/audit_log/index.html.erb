<h1 class="mb-4"><i class="bi bi-journal-text me-2"></i>Audit Log</h1>

<div class="card mb-4">
  <div class="card-body">
    <%= form_tag admin_audit_log_index_path, method: :get, class: "row g-2 align-items-end" do %>
      <div class="col-md-2">
        <%= label_tag :model, "Model", class: "form-label" %>
        <%= select_tag :model, options_for_select([["All Models", ""]] + @tracked_models.map { |m| [m, m] }, params[:model]), class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <%= label_tag :event, "Event", class: "form-label" %>
        <%= select_tag :event, options_for_select([["All Events", ""], ["Create", "create"], ["Update", "update"], ["Destroy", "destroy"]], params[:event]), class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-2">
        <%= label_tag :item_id, "Item ID", class: "form-label" %>
        <%= text_field_tag :item_id, params[:item_id], class: "form-control form-control-sm", placeholder: "e.g. 42" %>
      </div>
      <div class="col-md-2">
        <%= label_tag :from, "From", class: "form-label" %>
        <%= date_field_tag :from, params[:from], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <%= label_tag :to, "To", class: "form-label" %>
        <%= date_field_tag :to, params[:to], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <%= submit_tag "Filter", class: "btn btn-sm btn-primary w-100" %>
      </div>
    <% end %>
  </div>
</div>

<table class="table table-hover table-sm">
  <thead>
    <tr>
      <th>When</th>
      <th>Who</th>
      <th>Event</th>
      <th>Model</th>
      <th>Item ID</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @versions.each do |version| %>
      <tr>
        <td><%= version.created_at.strftime("%b %d, %Y %I:%M %p") %></td>
        <td>
          <% if version.whodunnit.present? %>
            <% actor = User.with_deleted.find_by(id: version.whodunnit) %>
            <%= actor ? actor.full_name : "User ##{version.whodunnit}" %>
          <% else %>
            <span class="text-muted">System</span>
          <% end %>
        </td>
        <td>
          <span class="badge bg-<%= version.event == 'create' ? 'success' : version.event == 'update' ? 'info' : 'danger' %>">
            <%= version.event %>
          </span>
        </td>
        <td><%= version.item_type %></td>
        <td><%= version.item_id %></td>
        <td>
          <%= link_to "Details", admin_audit_log_path(version), class: "btn btn-sm btn-outline-secondary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @versions.empty? %>
  <p class="text-muted text-center mt-4">No audit log entries found.</p>
<% end %>

<div class="mt-3">
  <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
</div>
