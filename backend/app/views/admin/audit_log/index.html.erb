<h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">&#128221; Audit Log</h1>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6 mb-6">
  <%= form_tag admin_audit_log_index_path, method: :get, class: "grid grid-cols-2 md:grid-cols-6 gap-3 items-end" do %>
    <div>
      <%= label_tag :model, "Model", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= select_tag :model, options_for_select([["All Models", ""]] + @tracked_models.map { |m| [m, m] }, params[:model]), class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>
    <div>
      <%= label_tag :event, "Event", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= select_tag :event, options_for_select([["All Events", ""], ["Create", "create"], ["Update", "update"], ["Destroy", "destroy"]], params[:event]), class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>
    <div>
      <%= label_tag :item_id, "Item ID", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= text_field_tag :item_id, params[:item_id], class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500", placeholder: "e.g. 42" %>
    </div>
    <div>
      <%= label_tag :from, "From", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= date_field_tag :from, params[:from], class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>
    <div>
      <%= label_tag :to, "To", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
      <%= date_field_tag :to, params[:to], class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>
    <div>
      <%= submit_tag "Filter", class: "w-full bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-600 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 dark:bg-slate-700">
      <tr>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">When</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Who</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Event</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Model</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Item ID</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
      <% @versions.each do |version| %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700">
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= version.created_at.strftime("%b %d, %Y %I:%M %p") %></td>
          <td class="px-4 py-3 text-slate-900 dark:text-white">
            <% if version.whodunnit.present? %>
              <% actor = User.with_deleted.find_by(id: version.whodunnit) %>
              <%= actor ? actor.full_name : "User ##{version.whodunnit}" %>
            <% else %>
              <span class="text-slate-400">System</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= version.event == 'create' ? 'bg-green-50 dark:bg-green-950 text-status-approved' : version.event == 'update' ? 'bg-blue-50 dark:bg-blue-950 text-blue-600' : 'bg-red-50 dark:bg-red-950 text-status-rejected' %>">
              <%= version.event %>
            </span>
          </td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= version.item_type %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= version.item_id %></td>
          <td class="px-4 py-3">
            <%= link_to "Details", admin_audit_log_path(version), class: "text-primary-500 hover:text-primary-700 text-xs font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @versions.empty? %>
  <p class="text-slate-400 text-center mt-6">No audit log entries found.</p>
<% end %>

<div class="mt-4">
  <%== @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
</div>
