<%= form_with(model: [:admin, category], class: "needs-validation") do |f| %>
  <% if category.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :color, class: "form-label" %>
        <%= f.color_field :color, class: "form-control form-control-color" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 3 %>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_categories_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
