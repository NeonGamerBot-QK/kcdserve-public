<%= form_with(model: [:admin, category], html: { novalidate: true }) do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 mb-6">
      <ul class="list-disc list-inside text-sm">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl border border-gray-200 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-slate-200 rounded-xl bg-slate-50 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", required: true %>
      </div>
      <div>
        <%= f.label :color, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.color_field :color, class: "w-16 h-10 border border-slate-200 rounded-xl cursor-pointer" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :description, class: "w-full px-3 py-2 border border-slate-200 rounded-xl bg-slate-50 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", rows: 3 %>
      </div>
      <div class="md:col-span-2">
        <div class="flex items-center">
          <%= f.check_box :restitution, class: "mr-2 h-4 w-4 rounded border-slate-300 text-primary-500 focus:ring-primary-500" %>
          <%= f.label :restitution, "Community Restitution", class: "text-sm text-slate-700" %>
        </div>
        <p class="text-xs text-slate-400 mt-1">Hours in this category are tracked separately and do not count toward volunteer totals.</p>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center space-x-3">
    <%= f.submit class: "bg-primary-500 text-white px-5 py-2 rounded-xl text-sm font-medium hover:bg-primary-600 cursor-pointer" %>
    <%= link_to "Cancel", admin_categories_path, class: "border border-slate-300 text-slate-700 px-5 py-2 rounded-xl text-sm font-medium hover:bg-slate-50" %>
  </div>
<% end %>
