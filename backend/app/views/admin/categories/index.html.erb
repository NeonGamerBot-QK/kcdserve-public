<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Categories</h1>
  <%= link_to "New Category", new_admin_category_path, class: "bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-600" %>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 dark:bg-slate-700">
      <tr>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Color</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Name</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Description</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Type</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
      <% @categories.each do |cat| %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700">
          <td class="px-4 py-3"><span class="inline-block w-6 h-6 rounded-full" style="background-color: <%= cat.color %>;"></span></td>
          <td class="px-4 py-3 text-slate-900 dark:text-white font-medium"><%= cat.name %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= truncate(cat.description, length: 60) %></td>
          <td class="px-4 py-3">
            <% if cat.restitution? %>
              <span class="px-2 py-0.5 rounded-full bg-amber-50 dark:bg-amber-950 text-status-pending text-xs font-medium">Community Restitution</span>
            <% end %>
          </td>
          <td class="px-4 py-3 space-x-2">
            <%= link_to "Edit", edit_admin_category_path(cat), class: "text-primary-500 hover:text-primary-700 text-xs font-medium" %>
            <%= button_to "Delete", admin_category_path(cat), method: :delete, class: "text-red-500 hover:text-red-700 text-xs font-medium", data: { turbo_confirm: "Delete #{cat.name}?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
