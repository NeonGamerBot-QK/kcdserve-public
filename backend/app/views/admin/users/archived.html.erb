<h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Archived Users</h1>

<div class="flex items-center space-x-2 mb-6">
  <%= link_to "All Archived", archived_admin_users_path, class: "px-4 py-1.5 rounded-full text-sm font-medium #{params[:filter].blank? ? 'bg-primary-500 text-white' : 'border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700'}" %>
  <%= link_to "Deleted 7+ Years Ago", archived_admin_users_path(filter: "7_years"), class: "px-4 py-1.5 rounded-full text-sm font-medium #{params[:filter] == '7_years' ? 'bg-primary-500 text-white' : 'border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700'}" %>
  <%= link_to "← Back to Active Users", admin_users_path, class: "ml-2 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300" %>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 dark:bg-slate-700">
      <tr>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Name</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Email</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Role</th>
        <th class="text-left px-4 py-3 text-slate-500 dark:text-slate-400 font-medium">Deleted On</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
      <% @users.each do |user| %>
        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700">
          <td class="px-4 py-3"><%= link_to user.full_name, admin_user_path(user), class: "text-primary-500 hover:text-primary-700 font-medium" %></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= user.email %></td>
          <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-xs font-medium"><%= user.role.humanize %></span></td>
          <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= user.deleted_at.strftime("%B %d, %Y") %></td>
          <td class="px-4 py-3">
            <%= button_to "Restore", restore_admin_user_path(user), method: :patch, class: "text-green-600 hover:text-green-700 text-xs font-medium", data: { turbo_confirm: "Restore this user?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @users.empty? %>
  <p class="text-slate-400 text-center mt-6">No archived users found.</p>
<% end %>

<div class="mt-4">
  <%== @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
</div>
