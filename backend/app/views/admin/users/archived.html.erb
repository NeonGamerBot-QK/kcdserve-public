<h1 class="mb-4">Archived Users</h1>

<div class="mb-3">
  <%= link_to "All Archived", archived_admin_users_path, class: "btn btn-sm #{params[:filter].blank? ? 'btn-primary' : 'btn-outline-primary'}" %>
  <%= link_to "Deleted 7+ Years Ago", archived_admin_users_path(filter: "7_years"), class: "btn btn-sm #{params[:filter] == '7_years' ? 'btn-primary' : 'btn-outline-primary'}" %>
  <%= link_to "← Back to Active Users", admin_users_path, class: "btn btn-sm btn-outline-secondary ms-2" %>
</div>

<table class="table table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Deleted On</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= link_to user.full_name, admin_user_path(user) %></td>
        <td><%= user.email %></td>
        <td><span class="badge bg-secondary"><%= user.role.humanize %></span></td>
        <td><%= user.deleted_at.strftime("%B %d, %Y") %></td>
        <td>
          <%= button_to "Restore", restore_admin_user_path(user), method: :patch, class: "btn btn-sm btn-outline-success", data: { turbo_confirm: "Restore this user?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @users.empty? %>
  <p class="text-muted text-center mt-4">No archived users found.</p>
<% end %>

<div class="mt-3">
  <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
</div>
