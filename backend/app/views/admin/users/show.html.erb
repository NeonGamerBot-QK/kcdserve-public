<h1>
  <%= @user.full_name %>
  <% if @user.deleted? %>
    <span class="badge bg-danger">Deactivated</span>
  <% end %>
</h1>

<div class="row mb-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <p><strong>Email:</strong> <%= @user.email %></p>
        <p><strong>Role:</strong> <span class="badge bg-secondary"><%= @user.role.humanize %></span></p>
        <p><strong>Phone:</strong> <%= @user.phone || "N/A" %></p>
        <p><strong>Provider:</strong> <%= @user.provider || "Email" %></p>
        <p><strong>Total Hours:</strong> <%= @user.total_approved_hours %></p>
        <p><strong>Joined:</strong> <%= @user.created_at.strftime("%B %d, %Y") %></p>
        <% if @user.deleted? %>
          <p><strong>Deleted On:</strong> <%= @user.deleted_at.strftime("%B %d, %Y") %></p>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="d-grid gap-2">
      <% if current_user.admin_or_above? && !@user.deleted? %>
        <%= link_to "Edit User", edit_admin_user_path(@user), class: "btn btn-outline-primary" %>
      <% end %>
      <% unless @user.deleted? %>
        <%= link_to "View Profile", profile_path(@user), class: "btn btn-outline-secondary" %>
      <% end %>
      <% if current_user.admin_or_above? && @user != current_user %>
        <% if @user.deleted? %>
          <%= button_to "Restore User", restore_admin_user_path(@user), method: :patch, class: "btn btn-outline-success", data: { turbo_confirm: "Restore this user?" } %>
        <% else %>
          <%= button_to "Deactivate User", admin_user_path(@user), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: "This will deactivate the user. Are you sure?" } %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<h4>Service Hours</h4>
<table class="table table-sm">
  <thead><tr><th>Date</th><th>Hours</th><th>Category</th><th>Status</th></tr></thead>
  <tbody>
    <% @service_hours.each do |sh| %>
      <tr>
        <td><%= sh.service_date.strftime("%m/%d/%Y") %></td>
        <td><%= sh.hours %></td>
        <td><%= sh.category.name %></td>
        <td>
          <span class="badge bg-<%= sh.approved? ? 'success' : sh.pending? ? 'warning' : 'danger' %>">
            <%= sh.status.humanize %>
          </span>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
