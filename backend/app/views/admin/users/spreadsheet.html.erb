<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">User Spreadsheet</h1>
  <div class="flex space-x-2">
    <%= link_to "← Standard View", admin_users_path, class: "border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700" %>
  </div>
</div>

<p class="text-sm text-slate-500 dark:text-slate-400 mb-4">Click any cell to edit. Changes save automatically on blur.</p>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 overflow-x-auto">
  <table class="w-full text-sm" id="spreadsheet-table">
    <thead class="bg-slate-50 dark:bg-slate-700 sticky top-0 z-10">
      <tr>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600 w-10">#</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">First Name</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Last Name</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Email</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Role</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Grade</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Phone</th>
        <th class="text-left px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap border-r border-slate-200 dark:border-slate-600">Groups</th>
        <th class="text-right px-3 py-2.5 text-slate-500 dark:text-slate-400 font-medium text-xs uppercase tracking-wider whitespace-nowrap">Hours</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
      <% @users.each_with_index do |user, idx| %>
        <tr class="hover:bg-blue-50/50 dark:hover:bg-slate-700/50 group" data-user-id="<%= user.id %>">
          <td class="px-3 py-2 text-slate-400 dark:text-slate-500 text-xs border-r border-slate-100 dark:border-slate-700"><%= idx + 1 %></td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <input type="text" value="<%= user.first_name %>" data-field="first_name"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset" />
          </td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <input type="text" value="<%= user.last_name %>" data-field="last_name"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset" />
          </td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <input type="email" value="<%= user.email %>" data-field="email"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset" />
          </td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <select data-field="role"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset cursor-pointer">
              <% User.roles.keys.each do |r| %>
                <option value="<%= r %>" <%= 'selected' if user.role == r %>><%= r.humanize %></option>
              <% end %>
            </select>
          </td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <select data-field="grade"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset cursor-pointer">
              <option value="" <%= 'selected' unless user.grade %>>—</option>
              <% (9..12).each do |g| %>
                <option value="<%= g %>" <%= 'selected' if user.grade == g %>><%= g %></option>
              <% end %>
            </select>
          </td>
          <td class="px-0 py-0 border-r border-slate-100 dark:border-slate-700">
            <input type="text" value="<%= user.phone || '' %>" data-field="phone"
              class="spreadsheet-cell w-full px-3 py-2 bg-transparent text-slate-900 dark:text-white text-sm border-0 outline-none focus:bg-blue-50 dark:focus:bg-slate-600 focus:ring-2 focus:ring-primary-500 focus:ring-inset" />
          </td>
          <td class="px-3 py-2 text-slate-600 dark:text-slate-300 border-r border-slate-100 dark:border-slate-700">
            <% if user.groups.any? %>
              <div class="flex flex-wrap gap-1">
                <% user.groups.each do |g| %>
                  <span class="inline-block px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-600 text-xs font-medium text-slate-600 dark:text-slate-300"><%= g.name %></span>
                <% end %>
              </div>
            <% else %>
              <span class="text-slate-400 dark:text-slate-500">—</span>
            <% end %>
          </td>
          <td class="px-3 py-2 text-right text-slate-600 dark:text-slate-300 font-medium"><%= user.total_approved_hours %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Save status toast -->
<div id="save-toast" class="fixed bottom-6 right-6 px-4 py-2.5 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 opacity-0 translate-y-2 pointer-events-none z-50"></div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
  const toast = document.getElementById('save-toast');
  let toastTimeout;

  /**
   * Displays a brief toast notification indicating save status.
   * @param {string} message - The message to display.
   * @param {boolean} success - Whether the save was successful.
   */
  function showToast(message, success) {
    clearTimeout(toastTimeout);
    toast.textContent = message;
    toast.className = 'fixed bottom-6 right-6 px-4 py-2.5 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 z-50 ' +
      (success
        ? 'bg-green-50 dark:bg-green-950 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-800'
        : 'bg-red-50 dark:bg-red-950 text-red-800 dark:text-red-300 border border-red-200 dark:border-red-800');
    toast.style.opacity = '1';
    toast.style.transform = 'translateY(0)';
    toastTimeout = setTimeout(function() {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(0.5rem)';
    }, 2000);
  }

  /**
   * Sends an inline update request for a single user field.
   * @param {string} userId - The user's ID.
   * @param {string} field - The field name to update.
   * @param {string} value - The new value.
   * @param {HTMLElement} cell - The input element for visual feedback.
   */
  function saveCell(userId, field, value, cell) {
    const body = { user: {} };
    body.user[field] = value === '' ? null : value;

    fetch('/admin/users/' + userId + '/inline_update', {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      },
      body: JSON.stringify(body)
    }).then(function(res) {
      if (res.ok) {
        cell.style.boxShadow = 'inset 0 0 0 2px #22c55e';
        showToast('Saved', true);
      } else {
        return res.json().then(function(data) {
          cell.style.boxShadow = 'inset 0 0 0 2px #ef4444';
          showToast(data.errors ? data.errors.join(', ') : 'Save failed', false);
        });
      }
      setTimeout(function() { cell.style.boxShadow = ''; }, 1500);
    }).catch(function() {
      cell.style.boxShadow = 'inset 0 0 0 2px #ef4444';
      showToast('Network error', false);
      setTimeout(function() { cell.style.boxShadow = ''; }, 1500);
    });
  }

  // Attach event listeners to all editable cells
  document.querySelectorAll('.spreadsheet-cell').forEach(function(cell) {
    var originalValue = cell.value;

    cell.addEventListener('focus', function() {
      originalValue = cell.value;
    });

    cell.addEventListener('blur', function() {
      if (cell.value !== originalValue) {
        var row = cell.closest('tr');
        var userId = row.dataset.userId;
        var field = cell.dataset.field;
        saveCell(userId, field, cell.value, cell);
      }
    });

    // Save on Enter key, move to next row on Tab
    cell.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        cell.blur();
      }
    });
  });

  // Select dropdowns save on change
  document.querySelectorAll('select.spreadsheet-cell').forEach(function(sel) {
    sel.addEventListener('change', function() {
      var row = sel.closest('tr');
      var userId = row.dataset.userId;
      var field = sel.dataset.field;
      saveCell(userId, field, sel.value, sel);
    });
  });
});
</script>
