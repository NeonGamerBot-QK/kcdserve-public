<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Manage Users</h1>
  <div>
    <%= link_to "Add User", new_admin_user_path, class: "btn btn-primary" %>
    <%= link_to "Archived Users", archived_admin_users_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
</div>

<table class="table table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Hours</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= link_to user.full_name, admin_user_path(user) %></td>
        <td><%= user.email %></td>
        <td><span class="badge bg-secondary"><%= user.role.humanize %></span></td>
        <td><%= user.total_approved_hours %></td>
        <td>
          <%= link_to "Edit", edit_admin_user_path(user), class: "btn btn-sm btn-outline-primary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mt-3">
  <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
</div>
