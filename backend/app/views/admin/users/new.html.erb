<h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Add New User</h1>

<%= form_with(model: @user, url: admin_users_path, html: { novalidate: true }) do |f| %>
  <% if @user.errors.any? %>
    <div class="bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 rounded-xl p-4 mb-6">
      <ul class="list-disc list-inside text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :first_name, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :last_name, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :role, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div class="md:col-span-1">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.email_field :email, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :phone, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_field :phone, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :birthday, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.date_field :birthday, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :grade, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.select :grade, (9..12).map { |g| ["Grade #{g}", g] }, { include_blank: "Not set" }, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" %>
      </div>
      <div class="md:col-span-3">
        <%= f.label :bio, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" %>
        <%= f.text_area :bio, class: "w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent", rows: 3 %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex items-center space-x-3">
    <%= f.submit "Create User", class: "bg-primary-500 text-white px-5 py-2 rounded-xl text-sm font-medium hover:bg-primary-600 cursor-pointer" %>
    <%= link_to "Cancel", admin_users_path, class: "border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 px-5 py-2 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700" %>
  </div>
<% end %>
