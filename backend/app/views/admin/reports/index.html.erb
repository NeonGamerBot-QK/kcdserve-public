<h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Reports & Analytics</h1>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6 mb-6">
  <%= form_with(url: admin_reports_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-4 items-end") do %>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Start Date</label>
      <input type="date" name="start_date" value="<%= params[:start_date] %>" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500">
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">End Date</label>
      <input type="date" name="end_date" value="<%= params[:end_date] %>" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500">
    </div>
    <div class="flex items-center space-x-2">
      <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-primary-600">Filter</button>
      <%= link_to "Reset", admin_reports_path, class: "border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700" %>
    </div>
    <div>
      <%= link_to "Export CSV", export_csv_admin_reports_path, class: "inline-block bg-status-approved text-white px-4 py-2 rounded-xl text-sm font-medium hover:opacity-90" %>
    </div>
  <% end %>
</div>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-6 mb-6 text-center">
  <p class="text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider font-medium">Total Approved Hours</p>
  <h2 class="text-4xl font-bold text-slate-900 dark:text-white mt-1"><%= @total_hours.to_f.round(1) %></h2>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-slate-700">
      <h5 class="font-semibold text-slate-900 dark:text-white">Monthly Trend</h5>
    </div>
    <div class="p-6">
      <%= line_chart @monthly_trend, colors: ["#3B82F6"] %>
    </div>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-slate-700">
      <h5 class="font-semibold text-slate-900 dark:text-white">Hours by Category</h5>
    </div>
    <div class="p-6">
      <%= pie_chart @hours_by_category %>
    </div>
  </div>
</div>

<% if @hours_by_group.any? %>
  <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 mb-6">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-slate-700">
      <h5 class="font-semibold text-slate-900 dark:text-white">Hours by Group</h5>
    </div>
    <div class="p-6">
      <%= bar_chart @hours_by_group, colors: ["#14B8A6"] %>
    </div>
  </div>
<% end %>

<div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-slate-700">
    <h5 class="font-semibold text-slate-900 dark:text-white">Top 25 Volunteers</h5>
  </div>
  <div class="p-6">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-slate-700">
          <th class="text-left py-2 text-slate-500 dark:text-slate-400 font-medium">#</th>
          <th class="text-left py-2 text-slate-500 dark:text-slate-400 font-medium">Name</th>
          <th class="text-left py-2 text-slate-500 dark:text-slate-400 font-medium">Email</th>
          <th class="text-left py-2 text-slate-500 dark:text-slate-400 font-medium">Hours</th>
        </tr>
      </thead>
      <tbody>
        <% @top_volunteers.each_with_index do |v, i| %>
          <tr class="border-b border-gray-100 dark:border-slate-700">
            <td class="py-2 text-slate-600 dark:text-slate-300"><%= i + 1 %></td>
            <td class="py-2"><%= link_to v.full_name, admin_user_path(v), class: "text-primary-500 hover:text-primary-700" %></td>
            <td class="py-2 text-slate-600 dark:text-slate-300"><%= v.email %></td>
            <td class="py-2 text-slate-600 dark:text-slate-300"><%= v.total_hours.to_f.round(1) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
