<%= form_with(model: group, class: "needs-validation") do |f| %>
  <% if group.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-4">
      <ul class="mb-0 list-disc list-inside">
        <% group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <div class="mb-4">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border rounded", required: true %>
      </div>
    </div>
    <div>
      <div class="mb-4">
        <%= f.label :leader_id, "Group Leader", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :leader_id, User.order(:last_name, :first_name), :id, :full_name, { include_blank: "No leader" }, class: "w-full px-3 py-2 border rounded" %>
      </div>
    </div>
    <div class="md:col-span-2">
      <div class="mb-4">
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, class: "w-full px-3 py-2 border rounded", rows: 4 %>
      </div>
    </div>
    <div>
      <div class="mb-4">
        <%= f.label :logo, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.file_field :logo, class: "w-full px-3 py-2 border rounded", accept: "image/*" %>
      </div>
    </div>
    <div>
      <div class="mb-4 h-full flex items-end">
        <div class="flex items-center">
          <%= f.check_box :invite_only, class: "mr-2 h-4 w-4", id: "invite_only" %>
          <%= f.label :invite_only, "Invite Only (private group)", class: "text-sm text-gray-700", for: "invite_only" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <%= f.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    <%= link_to "Cancel", groups_path, class: "ml-2 text-gray-600 hover:text-gray-800" %>
  </div>
<% end %>
