<%= form_with(model: group, class: "needs-validation") do |f| %>
  <% if group.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :leader_id, "Group Leader", class: "form-label" %>
        <%= f.collection_select :leader_id, User.order(:last_name, :first_name), :id, :full_name, { include_blank: "No leader" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4 %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :logo, class: "form-label" %>
        <%= f.file_field :logo, class: "form-control", accept: "image/*" %>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", groups_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
