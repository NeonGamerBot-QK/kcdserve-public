<div class="row">
  <div class="col-md-8">
    <div class="d-flex align-items-center mb-4">
      <% if @group.logo.attached? %>
        <%= image_tag @group.logo, class: "rounded-circle me-3", style: "width: 80px; height: 80px; object-fit: cover;" %>
      <% end %>
      <div>
        <h1 class="mb-0">
          <%= @group.name %>
          <% if @group.invite_only? %>
            <span class="badge bg-secondary ms-2" title="Invite Only">
              <i class="bi bi-lock-fill"></i> Private
            </span>
          <% end %>
        </h1>
        <% if @group.leader %>
          <p class="text-muted mb-0">Led by <%= @group.leader.full_name %></p>
        <% end %>
      </div>
    </div>

    <% if @group.description.present? %>
      <p><%= simple_format(@group.description) %></p>
    <% end %>

    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card text-center">
          <div class="card-body">
            <h3><%= @members.count %></h3>
            <p class="mb-0">Members</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center bg-primary text-white">
          <div class="card-body">
            <h3><%= @total_hours %></h3>
            <p class="mb-0">Total Hours</p>
          </div>
        </div>
      </div>
    </div>

    <h4>Members</h4>
    <table class="table">
      <thead><tr><th>Name</th><th>Hours</th></tr></thead>
      <tbody>
        <% @members.each do |member| %>
          <tr>
            <td><%= link_to member.full_name, profile_path(member) %></td>
            <td><%= member.total_approved_hours %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-body d-grid gap-2">
        <% if user_signed_in? %>
          <% if @is_member %>
            <%= button_to "Leave Group", leave_group_path(@group), method: :delete, class: "btn btn-outline-warning" %>
          <% elsif @group.invite_only? %>
            <p class="text-muted small mb-0"><i class="bi bi-lock-fill"></i> This group is invite only.</p>
          <% else %>
            <%= button_to "Join Group", join_group_path(@group), method: :post, class: "btn btn-primary" %>
          <% end %>
        <% elsif !@group.invite_only? %>
          <p><%= link_to "Sign in", new_user_session_path %> to join this group.</p>
        <% end %>

        <% if user_signed_in? && (current_user.admin_or_above? || @group.leader == current_user) %>
          <hr>
          <%= link_to "Edit Group", edit_group_path(@group), class: "btn btn-outline-secondary" %>
          <% if current_user.admin_or_above? %>
            <%= button_to "Delete Group", group_path(@group), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
