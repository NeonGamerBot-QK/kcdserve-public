<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="md:col-span-2">
    <div class="flex items-center mb-4">
      <% if @group.logo.attached? %>
        <%= image_tag @group.logo, class: "rounded-full mr-4", style: "width: 80px; height: 80px; object-fit: cover;" %>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-0">
          <%= @group.name %>
          <% if @group.invite_only? %>
            <span class="ml-2 px-2 py-1 bg-gray-200 dark:bg-slate-700 text-slate-900 dark:text-slate-300 rounded text-xs" title="Invite Only">
              Private
            </span>
          <% end %>
        </h1>
        <% if @group.leader %>
          <p class="text-gray-500 dark:text-slate-400 mb-0">Led by <%= @group.leader.full_name %></p>
        <% end %>
      </div>
    </div>

    <% if @group.description.present? %>
      <p class="mb-4 text-slate-700 dark:text-slate-300"><%= simple_format(@group.description) %></p>
    <% end %>

    <div class="grid grid-cols-2 gap-3 mb-6">
      <div class="bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm p-4 text-center">
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white"><%= @members.count %></h3>
        <p class="mb-0 text-slate-600 dark:text-slate-300">Members</p>
      </div>
      <div class="bg-blue-600 text-white rounded-lg p-4 text-center">
        <h3 class="text-2xl font-bold"><%= @total_hours %></h3>
        <p class="mb-0">Total Hours</p>
      </div>
    </div>

    <h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Members</h4>
    <div class="bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-slate-700">
          <tr>
            <th class="text-left px-4 py-2 text-sm font-medium text-gray-600 dark:text-slate-300">Name</th>
            <th class="text-left px-4 py-2 text-sm font-medium text-gray-600 dark:text-slate-300">Hours</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
          <% @members.each do |member| %>
            <tr>
              <td class="px-4 py-2 text-slate-900 dark:text-white"><%= link_to member.full_name, profile_path(member), class: "text-blue-600 hover:underline" %></td>
              <td class="px-4 py-2 text-slate-700 dark:text-slate-300"><%= member.total_approved_hours %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="md:col-span-1">
    <div class="bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm p-4">
      <div class="space-y-2">
        <% if user_signed_in? %>
          <% if @is_member %>
            <%= button_to "Leave Group", leave_group_path(@group), method: :delete, class: "w-full border border-yellow-500 text-yellow-600 dark:text-yellow-500 rounded px-4 py-2 hover:bg-yellow-50 dark:hover:bg-yellow-950" %>
          <% elsif @group.invite_only? %>
            <p class="text-gray-500 dark:text-slate-400 text-sm mb-0">This group is invite only.</p>
          <% else %>
            <%= button_to "Join Group", join_group_path(@group), method: :post, class: "w-full bg-blue-600 text-white rounded px-4 py-2 hover:bg-blue-700" %>
          <% end %>
        <% elsif !@group.invite_only? %>
          <p class="text-slate-700 dark:text-slate-300"><%= link_to "Sign in", new_user_session_path %> to join this group.</p>
        <% end %>

        <% if user_signed_in? && (current_user.admin_or_above? || @group.leader == current_user) %>
          <hr class="border-gray-200 dark:border-slate-700">
          <%= link_to "Edit Group", edit_group_path(@group), class: "block w-full text-center border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-slate-300 rounded px-4 py-2 hover:bg-gray-50 dark:hover:bg-slate-700" %>
          <% if current_user.admin_or_above? %>
            <%= button_to "Delete Group", group_path(@group), method: :delete, class: "w-full border border-red-500 text-red-500 rounded px-4 py-2 hover:bg-red-50 dark:hover:bg-red-950", data: { turbo_confirm: "Are you sure?" } %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
