<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Groups</h1>
  <% if user_signed_in? && current_user.admin_or_above? %>
    <%= link_to "New Group", new_group_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <% @groups.each do |group| %>
    <div class="bg-white rounded-lg border shadow-sm h-full">
      <div class="p-4">
        <div class="flex items-center mb-3">
          <% if group.logo.attached? %>
            <%= image_tag group.logo, class: "rounded-full mr-3", style: "width: 50px; height: 50px; object-fit: cover;" %>
          <% else %>
            <div class="rounded-full bg-gray-400 text-white flex items-center justify-content-center mr-3 flex-shrink-0" style="width: 50px; height: 50px;">
              <%= group.name[0] %>
            </div>
          <% end %>
          <div>
            <h5 class="mb-0 font-semibold"><%= group.name %></h5>
            <% if group.leader %>
              <small class="text-gray-500">Led by <%= group.leader.full_name %></small>
            <% end %>
          </div>
        </div>
        <p class="text-gray-600 mb-3"><%= truncate(group.description, length: 100) %></p>
        <div class="flex justify-between">
          <span class="text-gray-500 text-sm"><%= group.member_count %> members</span>
        </div>
      </div>
      <div class="bg-gray-50 px-4 py-3 border-t">
        <%= link_to "View Group", group_path(group), class: "text-blue-600 hover:text-blue-800 text-sm" %>
      </div>
    </div>
  <% end %>
</div>

<% if @groups.empty? %>
  <div class="text-center py-12">
    <p class="text-gray-500 text-lg">No groups yet.</p>
  </div>
<% end %>

<div class="mt-4">
  <%== bootstrap_series_nav(@pagy) if @pagy.pages > 1 %>
</div>
