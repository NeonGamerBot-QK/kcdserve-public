<nav class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700" data-controller="theme">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex items-center justify-between h-14">
      <%# Left: Avatar + Brand — matches mobile TopBar %>
      <div class="flex items-center space-x-3">
        <% if user_signed_in? %>
          <div class="w-9 h-9 rounded-full bg-accent-500 flex items-center justify-center">
            <span class="font-semibold text-white text-sm"><%= current_user.first_name[0] %></span>
          </div>
        <% else %>
          <div class="w-9 h-9 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
        <% end %>
        <% if user_signed_in? && (current_user.admin_or_above? || current_user.teacher?) %>
          <span class="border-2 border-dashed border-orange-400 rounded-lg px-2.5 py-0.5 bg-orange-50 dark:bg-orange-950">
            <%= link_to "KCDServe", root_path, class: "font-semibold text-lg text-slate-900 dark:text-white" %>
          </span>
        <% else %>
          <%= link_to "KCDServe", root_path, class: "font-semibold text-lg text-slate-900 dark:text-white" %>
        <% end %>
      </div>

      <%# Mobile toggle %>
      <button id="navbar-toggler" type="button" class="md:hidden p-2 text-slate-500 dark:text-slate-400" aria-label="Toggle navigation">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <%# Right: Nav links — styled as pills like mobile FilterChip %>
      <div id="navbar-collapse" class="hidden md:flex md:items-center space-x-1">
        <%= link_to "Opportunities", opportunities_path, class: "rounded-full px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" %>
        <%= link_to "Groups", groups_path, class: "rounded-full px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" %>
        <% if user_signed_in? && current_user.is_a?(User) %>
          <%= link_to "My Hours", service_hours_path, class: "rounded-full px-4 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" %>
          <%= link_to "Dashboard", dashboard_path, class: "rounded-full px-4 py-1.5 text-sm font-medium text-primary-500 hover:bg-primary-50 dark:hover:bg-primary-950" %>
        <% end %>

        <% if user_signed_in? && current_user.is_a?(User) %>
          <% if current_user.admin_or_above? || current_user.teacher? %>
            <%= link_to(current_user.admin_or_above? ? "Admin" : "Staff", admin_root_path, class: "rounded-full px-4 py-1.5 text-sm font-medium border-2 border-dashed border-orange-400 text-orange-500 hover:bg-orange-50 dark:hover:bg-orange-950") %>
          <% end %>

          <button type="button" class="rounded-full px-3 py-1.5 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" data-action="theme#toggle" data-theme-target="toggle">🌙 Dark</button>

          <div class="relative group ml-1">
            <button class="flex items-center space-x-1 rounded-full px-3 py-1.5 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800">
              <span><%= current_user.first_name %></span>
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="absolute right-0 mt-1 w-48 bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 shadow-lg hidden group-hover:block z-50 py-1">
              <%= link_to "My Profile", profile_path(current_user), class: "block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700" %>
              <%= link_to "Resume (PDF)", resume_path(current_user), class: "block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700" %>
              <%= link_to "Export CSV", resume_csv_path(current_user), class: "block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700" %>
              <div class="border-t border-gray-100 dark:border-slate-700 my-1"></div>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-red-50 dark:hover:bg-red-950" %>
            </div>
          </div>
        <% else %>
          <button type="button" class="rounded-full px-3 py-1.5 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800" data-action="theme#toggle" data-theme-target="toggle">🌙 Dark</button>
          <%= link_to "Sign In", root_path, class: "rounded-full px-4 py-1.5 text-sm font-medium bg-primary-500 text-white hover:bg-primary-600" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>

<script>
  document.getElementById('navbar-toggler').addEventListener('click', function() {
    const collapse = document.getElementById('navbar-collapse');
    collapse.classList.toggle('hidden');
  });
</script>
