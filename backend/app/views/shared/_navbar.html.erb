<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container">
    <%= link_to "KCDServe", root_path, class: "navbar-brand fw-bold" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <%= link_to "Opportunities", opportunities_path, class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Groups", groups_path, class: "nav-link" %>
        </li>
        <% if user_signed_in? && current_user.is_a?(User) %>
          <li class="nav-item">
            <%= link_to "My Hours", service_hours_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Dashboard", dashboard_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>

      <ul class="navbar-nav">
        <% if user_signed_in? && current_user.is_a?(User) %>
          <% if current_user.admin_or_above? || current_user.teacher? %>
            <% content_for :admin_css do %>
              <style>.admin-nav-btn { border: 2px dashed orange; border-radius: 6px; padding: 2px 10px; }</style>
            <% end %>
            <li class="nav-item">
              <%= link_to(current_user.admin_or_above? ? "Admin" : "Staff Portal", admin_root_path, class: "nav-link admin-nav-btn") %>
            </li>
          <% end %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i> <%= current_user.full_name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><%= link_to "My Profile", profile_path(current_user), class: "dropdown-item" %></li>
              <li><%= link_to "Download Resume (PDF)", resume_path(current_user), class: "dropdown-item" %></li>
              <li><%= link_to "Export Hours (CSV)", resume_csv_path(current_user), class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "dropdown-item" %></li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign In", root_path, class: "btn btn-outline-light ms-2" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
