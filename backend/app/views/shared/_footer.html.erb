<footer class="bg-dark text-light py-4 mt-5">
  <div class="container">
    <div class="row">
      <div class="col-md-6">
        <h5>KCDServe</h5>
        <p class="text-muted">Community Service Hour Logging Platform</p>
      </div>
      <div class="col-md-3">
        <h6>Quick Links</h6>
        <ul class="list-unstyled">
          <li><%= link_to "Opportunities", opportunities_path, class: "text-muted" %></li>
          <li><%= link_to "Groups", groups_path, class: "text-muted" %></li>
        </ul>
      </div>
      <div class="col-md-3">
        <h6>Account</h6>
        <ul class="list-unstyled">
          <% if user_signed_in? %>
            <li><%= link_to "Dashboard", dashboard_path, class: "text-muted" %></li>
            <li><%= link_to "My Profile", profile_path(current_user), class: "text-muted" %></li>
          <% else %>
            <li><%= link_to "Sign In", root_path, class: "text-muted" %></li>
          <% end %>
        </ul>
      </div>
    </div>
    <hr class="border-secondary">
    <p class="text-center text-muted mb-0">&copy; <%= Date.current.year %> KCDServe. All rights reserved.</p>
  </div>
</footer>
