<footer class="border-t border-gray-200 dark:border-slate-700 mt-12 py-8 bg-white dark:bg-slate-900">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <p class="font-semibold text-lg text-slate-900 dark:text-white mb-1">KCDServe</p>
        <p class="text-sm text-slate-400">Community Service Hour Logging Platform</p>
      </div>
      <div>
        <p class="font-semibold text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Quick Links</p>
        <ul class="space-y-1">
          <li><%= link_to "Opportunities", opportunities_path, class: "text-sm text-slate-500 dark:text-slate-400 hover:text-primary-500" %></li>
          <li><%= link_to "Groups", groups_path, class: "text-sm text-slate-500 dark:text-slate-400 hover:text-primary-500" %></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Account</p>
        <ul class="space-y-1">
          <% if user_signed_in? %>
            <li><%= link_to "Dashboard", dashboard_path, class: "text-sm text-slate-500 dark:text-slate-400 hover:text-primary-500" %></li>
            <li><%= link_to "My Profile", profile_path(current_user), class: "text-sm text-slate-500 dark:text-slate-400 hover:text-primary-500" %></li>
          <% else %>
            <li><%= link_to "Sign In", root_path, class: "text-sm text-slate-500 dark:text-slate-400 hover:text-primary-500" %></li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-100 dark:border-slate-700 mt-6 pt-6">
      <p class="text-center text-xs text-slate-400">&copy; <%= Date.current.year %> KCDServe. All rights reserved.</p>
    </div>
  </div>
</footer>
