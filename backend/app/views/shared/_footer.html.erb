<footer class="bg-gray-800 text-gray-300 py-8 mt-12">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h5 class="text-white font-bold text-lg mb-2">KCDServe</h5>
        <p class="text-gray-400">Community Service Hour Logging Platform</p>
      </div>
      <div>
        <h6 class="text-white font-semibold mb-2">Quick Links</h6>
        <ul class="space-y-1">
          <li><%= link_to "Opportunities", opportunities_path, class: "text-gray-400 hover:text-white" %></li>
          <li><%= link_to "Groups", groups_path, class: "text-gray-400 hover:text-white" %></li>
        </ul>
      </div>
      <div>
        <h6 class="text-white font-semibold mb-2">Account</h6>
        <ul class="space-y-1">
          <% if user_signed_in? %>
            <li><%= link_to "Dashboard", dashboard_path, class: "text-gray-400 hover:text-white" %></li>
            <li><%= link_to "My Profile", profile_path(current_user), class: "text-gray-400 hover:text-white" %></li>
          <% else %>
            <li><%= link_to "Sign In", root_path, class: "text-gray-400 hover:text-white" %></li>
          <% end %>
        </ul>
      </div>
    </div>
    <hr class="border-gray-700 my-6">
    <p class="text-center text-gray-500 mb-0">&copy; <%= Date.current.year %> KCDServe. All rights reserved.</p>
  </div>
</footer>
