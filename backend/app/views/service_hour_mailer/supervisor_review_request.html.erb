<p style="margin: 0 0 16px; font-size: 16px; color: #1e293b;">Hi <%= @service_hour.contact_name.present? ? @service_hour.contact_name : "there" %>,</p>

<p style="margin: 0 0 24px; font-size: 15px; color: #475569; line-height: 1.6;">
  <strong style="color: #1e293b;"><%= @user.full_name %></strong> has submitted volunteer service hours
  and listed you as their supervisor. Please review the details below and approve or reject the submission.
</p>

<!-- Submission details -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 24px;">
  <tr>
    <td style="padding: 20px 24px;">
      <table role="presentation" cellpadding="0" cellspacing="0" style="font-size: 14px; color: #475569; line-height: 2;">
        <tr>
          <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Student</td>
          <td style="font-weight: 500; color: #1e293b;"><%= @user.full_name %></td>
        </tr>
        <tr>
          <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Date of Service</td>
          <td style="font-weight: 500; color: #1e293b;"><%= @service_hour.service_date.strftime("%B %d, %Y") %></td>
        </tr>
        <tr>
          <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Hours</td>
          <td style="font-weight: 500; color: #1e293b;"><%= @service_hour.hours %></td>
        </tr>
        <tr>
          <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Category</td>
          <td style="font-weight: 500; color: #1e293b;"><%= @service_hour.category.name %></td>
        </tr>
        <% if @service_hour.organization_name.present? %>
          <tr>
            <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Organization</td>
            <td style="font-weight: 500; color: #1e293b;"><%= @service_hour.organization_name %></td>
          </tr>
        <% end %>
        <% if @service_hour.location.present? %>
          <tr>
            <td style="padding-right: 16px; color: #94a3b8; white-space: nowrap;">Location</td>
            <td style="font-weight: 500; color: #1e293b;"><%= @service_hour.location %></td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<!-- Description -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;">
  <tr>
    <td style="border-left: 3px solid #e2e8f0; padding: 12px 16px; background-color: #f8fafc; border-radius: 0 8px 8px 0;">
      <p style="margin: 0 0 4px; font-size: 12px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">Description</p>
      <p style="margin: 0; font-size: 14px; color: #1e293b; line-height: 1.6;"><%= @service_hour.description %></p>
    </td>
  </tr>
</table>

<!-- Action buttons -->
<p style="margin: 0 0 16px; font-size: 14px; color: #475569;">Click one of the buttons below to record your decision:</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;">
  <tr>
    <td style="padding-right: 12px;">
      <a href="<%= @approve_url %>"
         style="display: inline-block; padding: 12px 28px; background-color: #16a34a; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; border-radius: 8px;">
        &#10003;&nbsp; Approve Hours
      </a>
    </td>
    <td>
      <a href="<%= @reject_url %>"
         style="display: inline-block; padding: 12px 28px; background-color: #dc2626; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; border-radius: 8px;">
        &#10005;&nbsp; Reject Hours
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0; font-size: 13px; color: #94a3b8; line-height: 1.6;">
  These links are unique to this submission. If you did not supervise this student or received this email in error,
  you can safely ignore it. If you reject the hours, the submission will be automatically declined.
</p>
