<div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex items-center justify-center px-4">
  <div class="max-w-lg w-full bg-white dark:bg-slate-800 rounded-2xl border border-gray-200 dark:border-slate-700 p-8">
    <div class="w-14 h-14 bg-red-100 dark:bg-red-950 rounded-full flex items-center justify-center mb-4">
      <span style="font-size: 24px;">&#10005;</span>
    </div>
    <h1 class="text-xl font-semibold text-slate-900 dark:text-white mb-1">Reject Service Hours</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">
      You are rejecting <strong class="text-slate-700 dark:text-slate-300"><%= @service_hour.user.full_name %></strong>'s
      <%= @service_hour.hours %> hours on <%= @service_hour.service_date.strftime("%B %d, %Y") %>.
      Please provide a reason — the student will be notified.
    </p>

    <% if flash[:error].present? %>
      <div class="mb-4 text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded-xl px-4 py-3">
        <%= flash[:error] %>
      </div>
    <% end %>

    <%= form_with url: supervisor_review_reject_path(@service_hour.supervisor_token), method: :post, local: true do |f| %>
      <div class="mb-5">
        <%= f.label :reason, "Reason for rejection", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5" %>
        <%= f.text_area :reason, rows: 4, required: true,
              placeholder: "e.g. I did not supervise this student on that date.",
              class: "w-full px-3 py-2.5 border border-slate-200 dark:border-slate-600 rounded-xl bg-slate-50 dark:bg-slate-700 text-sm text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none" %>
      </div>
      <div class="flex gap-3">
        <%= f.submit "Confirm Rejection", class: "flex-1 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold py-2.5 rounded-xl cursor-pointer" %>
        <%= link_to "Cancel", supervisor_review_approve_path(@service_hour.supervisor_token),
              class: "flex-1 text-center border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-medium py-2.5 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
