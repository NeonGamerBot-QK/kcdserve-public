<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>My Service Hours</h1>
  <%= link_to "Log New Hours", new_service_hour_path, class: "btn btn-primary" %>
</div>

<% if @service_hours.any? %>
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Date</th>
        <th>Hours</th>
        <th>Category</th>
        <th>Group</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @service_hours.each do |sh| %>
        <tr>
          <td><%= sh.service_date.strftime("%m/%d/%Y") %></td>
          <td><%= sh.hours %></td>
          <td><%= sh.category.name %></td>
          <td><%= sh.group&.name || "—" %></td>
          <td>
            <span class="badge bg-<%= sh.approved? ? 'success' : sh.pending? ? 'warning' : 'danger' %>">
              <%= sh.status.humanize %>
            </span>
          </td>
          <td><%= link_to "View", service_hour_path(sh), class: "btn btn-sm btn-outline-primary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-3">
    <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="bi bi-clock display-1 text-muted"></i>
    <p class="lead text-muted mt-3">You haven't logged any service hours yet.</p>
    <%= link_to "Log Your First Hours", new_service_hour_path, class: "btn btn-primary" %>
  </div>
<% end %>
