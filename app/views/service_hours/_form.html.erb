<%= form_with(model: service_hour, class: "needs-validation") do |f| %>
  <% if service_hour.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(service_hour.errors.count, "error") %> prevented saving:</h6>
      <ul class="mb-0">
        <% service_hour.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :service_date, "Date of Service", class: "form-label" %>
        <%= f.date_field :service_date, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :hours, class: "form-label" %>
        <%= f.number_field :hours, class: "form-control", step: 0.25, min: 0.25, required: true %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :category_id, "Category", class: "form-label" %>
        <%= f.collection_select :category_id, Category.order(:name), :id, :name, { prompt: "Select category" }, class: "form-select", required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :group_id, "Group (optional)", class: "form-label" %>
        <%= f.collection_select :group_id, current_user.groups.order(:name), :id, :name, { include_blank: "No group" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :opportunity_id, "Opportunity (optional)", class: "form-label" %>
        <%= f.collection_select :opportunity_id, Opportunity.published.order(:title), :id, :title, { include_blank: "No specific opportunity" }, class: "form-select" %>
      </div>
    </div>
    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, "Description of Service", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4, required: true %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :photos, "Photo Proof (optional)", class: "form-label" %>
        <%= f.file_field :photos, class: "form-control", multiple: true, accept: "image/*" %>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", service_hours_path, class: "btn btn-outline-secondary ms-2" %>
  </div>
<% end %>
