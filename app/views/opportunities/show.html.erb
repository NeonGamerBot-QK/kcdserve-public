<div class="row">
  <div class="col-md-8">
    <h1><%= @opportunity.title %></h1>
    <div class="mb-3">
      <% if @opportunity.category %>
        <span class="badge" style="background-color: <%= @opportunity.category.color %>;">
          <%= @opportunity.category.name %>
        </span>
      <% end %>
      <% unless @opportunity.published? %>
        <span class="badge bg-secondary">Draft</span>
      <% end %>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <p><i class="bi bi-calendar me-2"></i><strong>Date:</strong> <%= @opportunity.date.strftime("%B %d, %Y") %></p>
            <% if @opportunity.start_time %>
              <p><i class="bi bi-clock me-2"></i><strong>Time:</strong> <%= @opportunity.start_time.strftime("%I:%M %p") %><%= " — #{@opportunity.end_time.strftime('%I:%M %p')}" if @opportunity.end_time %></p>
            <% end %>
          </div>
          <div class="col-md-6">
            <p><i class="bi bi-geo-alt me-2"></i><strong>Location:</strong> <%= @opportunity.location || "TBD" %></p>
            <% if @opportunity.required_hours %>
              <p><i class="bi bi-hourglass me-2"></i><strong>Required Hours:</strong> <%= @opportunity.required_hours %></p>
            <% end %>
            <% if @opportunity.max_volunteers %>
              <p><i class="bi bi-people me-2"></i><strong>Spots:</strong> <%= @opportunity.spots_remaining %> of <%= @opportunity.max_volunteers %> remaining</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <h5>Description</h5>
      <p><%= simple_format(@opportunity.description) %></p>
    </div>

    <% if @opportunity.photos.attached? %>
      <h5>Photos</h5>
      <div class="row g-2 mb-4">
        <% @opportunity.photos.each do |photo| %>
          <div class="col-md-4">
            <%= image_tag photo, class: "img-fluid rounded" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <% if user_signed_in? %>
          <% if @signed_up %>
            <p class="text-success"><i class="bi bi-check-circle me-1"></i> You are signed up!</p>
            <%= button_to "Withdraw", withdraw_opportunity_path(@opportunity), method: :delete, class: "btn btn-outline-danger w-100" %>
          <% elsif !@opportunity.full? %>
            <%= button_to "Sign Up", signup_opportunity_path(@opportunity), method: :post, class: "btn btn-primary w-100" %>
          <% else %>
            <p class="text-danger">This opportunity is full.</p>
          <% end %>
        <% else %>
          <p>Please <%= link_to "sign in", new_user_session_path %> to sign up.</p>
        <% end %>

        <hr>

        <% if user_signed_in? && current_user.admin_or_above? %>
          <div class="d-grid gap-2">
            <%= link_to "Edit", edit_opportunity_path(@opportunity), class: "btn btn-outline-secondary" %>
            <%= button_to "Delete", opportunity_path(@opportunity), method: :delete, class: "btn btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
          </div>
          <hr>
          <p class="text-muted mb-1"><strong>Signed up:</strong> <%= @opportunity.volunteers.count %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
