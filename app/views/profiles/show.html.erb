<div class="row">
  <div class="col-md-4 text-center">
    <% if @user.avatar.attached? %>
      <%= image_tag @user.avatar, class: "rounded-circle mb-3", style: "width: 150px; height: 150px; object-fit: cover;" %>
    <% else %>
      <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 150px; height: 150px; font-size: 3rem;">
        <%= @user.first_name[0] %><%= @user.last_name[0] %>
      </div>
    <% end %>
    <h3><%= @user.full_name %></h3>
    <p class="text-muted"><%= @user.role.humanize %></p>
    <% if @user.bio.present? %>
      <p><%= @user.bio %></p>
    <% end %>
    <% if @user.phone.present? %>
      <p><i class="bi bi-phone me-1"></i> <%= @user.phone %></p>
    <% end %>
    <% if @user == current_user %>
      <div class="mt-3">
        <%= link_to "Edit Profile", edit_profile_path(@user), class: "btn btn-outline-primary btn-sm" %>
        <%= link_to "Download Resume", resume_path(@user), class: "btn btn-outline-secondary btn-sm" %>
      </div>
    <% end %>
  </div>

  <div class="col-md-8">
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card text-center bg-primary text-white">
          <div class="card-body">
            <h3><%= @total_hours %></h3>
            <p class="mb-0">Approved Hours</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center">
          <div class="card-body">
            <h3><%= @groups.count %></h3>
            <p class="mb-0">Groups</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card text-center">
          <div class="card-body">
            <h3><%= @service_hours.count %></h3>
            <p class="mb-0">Entries</p>
          </div>
        </div>
      </div>
    </div>

    <% if @hours_by_category.any? %>
      <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Hours by Category</h5></div>
        <div class="card-body">
          <table class="table table-sm">
            <% @hours_by_category.each do |name, hours| %>
              <tr>
                <td><%= name %></td>
                <td class="text-end"><strong><%= hours.to_f.round(2) %></strong> hrs</td>
              </tr>
            <% end %>
          </table>
        </div>
      </div>
    <% end %>

    <% if @groups.any? %>
      <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Groups</h5></div>
        <ul class="list-group list-group-flush">
          <% @groups.each do |group| %>
            <li class="list-group-item">
              <%= link_to group.name, group_path(group) %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card">
      <div class="card-header"><h5 class="mb-0">Service History</h5></div>
      <div class="card-body">
        <% if @service_hours.any? %>
          <table class="table table-sm">
            <thead><tr><th>Date</th><th>Category</th><th>Hours</th></tr></thead>
            <tbody>
              <% @service_hours.limit(15).each do |sh| %>
                <tr>
                  <td><%= sh.service_date.strftime("%m/%d/%Y") %></td>
                  <td><%= sh.category.name %></td>
                  <td><%= sh.hours %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-muted">No service history yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
